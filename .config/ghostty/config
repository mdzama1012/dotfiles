# Ghostty configuration file

# Use Ctrl + , to reload the configuration file.

# Font Settings
font-size =
font-family = JetBrains Mono Nerd Font

# Background
# background-blur = true
background-opacity = 0.8

# Themes
# theme = GruvboxDarkHard
theme = IC_Orange_PPL
# theme = Monokai Soda
# theme = citruszest
# theme = CutiePro

# Mouse Behavior
mouse-hide-while-typing = true

# Cursor
cursor-style = bar
adjust-cursor-thickness = 2

# Specify the initial window size in grid cells:
# window-width = 80
# window-height = 24
maximize = true

bold-is-bright = true
window-inherit-font-size = false

# Auto update feature.
auto-update = check
